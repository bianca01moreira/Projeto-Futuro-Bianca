from banco import conectar
from validacoes import validar_email, validar_cpf
import sqlite3

def solicitar_acesso():
    print("SOLICITAR ACESSO")

    nome = input("Nome: ").strip()
    email = input("Email: ").strip()
    cpf = input("CPF: ").strip()
    cargo = input("Cargo: ").strip()
    empresa = input("Empresa: ").strip()

    if not nome or not email or not cpf:
        print("Preencha os campos obrigatórios")
        return

    if not validar_email(email):
        print("Email inválido")
        return

    if not validar_cpf(cpf):
        print("CPF inválido")
        return

    try:
        with conectar() as conn:
            cursor = conn.cursor()
            cursor.execute("""
                INSERT INTO solicitacoes (nome, email, cpf, cargo, empresa)
                VALUES (?, ?, ?, ?, ?)
            """, (nome, email, cpf, cargo, empresa))

        print("Solicitação enviada!")

    except sqlite3.IntegrityError:
        print("Email ou CPF já cadastrado")


def listar_solicitacoes():
    print("/SOLICITACOES")

    with conectar() as conn:
        cursor = conn.cursor()
        cursor.execute("SELECT * FROM solicitacoes WHERE status = 'pendente'")
        dados = cursor.fetchall()

    if not dados:
        print("Nenhuma solicitação pendente.")
        return

    for s in dados:
        id, nome, email, cpf, cargo, empresa, status = s

        print(f"""
        ID: {id}
        Nome: {nome}
        Email: {email}
        CPF: {cpf}
        Cargo: {cargo}
        Empresa: {empresa}
        Status: {status}
        """)
